---
const {
  title = "Xinyu Zhang",
  description = "Personal site for Xinyu Zhang."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f7f4;
        --ink: #1f2428;
        --muted: #5f686f;
        --line: #dfe3df;
        --panel: #ffffff;
        --accent: #1967d2;
        --accent-ink: #0f3f82;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.55;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      header {
        border-bottom: 1px solid var(--line);
        background: rgba(247, 247, 244, 0.92);
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        max-width: 960px;
        margin: 0 auto;
        padding: 18px 24px;
      }

      .brand {
        color: var(--ink);
        font-weight: 700;
        text-decoration: none;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 16px;
        font-size: 0.95rem;
      }

      .nav-links a {
        color: var(--muted);
        text-decoration: none;
      }

      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 56px 24px 80px;
      }

      .hero {
        display: grid;
        gap: 18px;
        max-width: 760px;
        padding: 16px 0 28px;
      }

      .eyebrow {
        color: var(--accent-ink);
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0;
        margin: 0;
      }

      h1 {
        font-size: clamp(2.2rem, 6vw, 4.4rem);
        line-height: 1.02;
        letter-spacing: 0;
        margin: 0;
      }

      h2 {
        font-size: 1.35rem;
        margin: 34px 0 10px;
      }

      p {
        margin: 0 0 14px;
      }

      .lede {
        color: var(--muted);
        font-size: 1.18rem;
        max-width: 720px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
        margin-top: 28px;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 20px;
      }

      .card h2,
      .card h3 {
        margin-top: 0;
      }

      .card h3 {
        font-size: 1.08rem;
      }

      .muted {
        color: var(--muted);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 16px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 10px 14px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        color: var(--ink);
        font-weight: 700;
        text-decoration: none;
      }

      .button.primary {
        border-color: var(--accent);
        background: var(--accent);
        color: white;
      }

      footer {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px 40px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 640px) {
        nav {
          align-items: flex-start;
          flex-direction: column;
        }

        main {
          padding-top: 36px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <nav aria-label="Primary">
        <a class="brand" href="/">Xinyu Zhang</a>
        <div class="nav-links">
          <a href="/music-mirror/">Music Mirror</a>
          <a href="/blog/">Blog</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 Xinyu Zhang</p>
    </footer>
  </body>
</html>
